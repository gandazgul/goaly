<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
		<link rel="manifest" href="/site.webmanifest">
		<meta name="theme-color" content="#ffffff">
		<meta name="apple-mobile-web-app-capable" content="yes">
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
		<meta name="generator" content={Astro.generator} />
		<title>Goaly</title>
		<script>
			if ('serviceWorker' in navigator) {
				window.addEventListener('load', () => {
					navigator.serviceWorker.register('/sw.js').then(
						() => console.log('ServiceWorker registered'),
						(err) => console.log('ServiceWorker registration failed: ', err)
					);
				});
			}
		</script>
	</head>
	<body class="flex flex-col min-h-screen bg-gray-50">
		<main class="flex-grow">
			<slot />
		</main>
		<footer class="bg-white border-t border-gray-200 py-6 text-center text-sm text-gray-500 font-sans mt-auto">
			<div class="flex justify-center gap-4">
				<a href="/privacy" class="hover:text-blue-600 transition">Privacy Policy</a>
				<span>&middot;</span>
				<a href="/terms" class="hover:text-blue-600 transition">Terms of Service</a>
			</div>
			<p class="mt-2">&copy; {new Date().getFullYear()} Goaly. All rights reserved.</p>
		</footer>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
