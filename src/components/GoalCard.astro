---
const { goal, timezone = 'UTC' } = Astro.props;

// Formatting helpers
const formatDuration = (minutes) => {
  if (minutes < 60) return `${minutes} min`;
  const h = Math.floor(minutes / 60);
  const m = minutes % 60;
  return m > 0 ? `${h}h ${m}m` : `${h} hr`;
};

const formatTimes = (times) => {
  if (times === 7) return 'Every day';
  if (times === 1) return 'Once a week';
  return `${times}x a week`;
};

const formatDateTime = (isoString, tz) => {
  if (!isoString) return 'None scheduled yet';
  const date = new Date(isoString);
  return new Intl.DateTimeFormat('en-US', {
    timeZone: tz,
    weekday: 'short',
    month: 'short',
    day: 'numeric',
    hour: 'numeric',
    minute: '2-digit',
    timeZoneName: 'short'
  }).format(date);
};

const bgColors = {
  '1': 'bg-[#7986cb]',
  '2': 'bg-[#33b679]',
  '3': 'bg-[#8e24aa]',
  '4': 'bg-[#e67c73]',
  '5': 'bg-[#f6c026]',
  '6': 'bg-[#f4511e]',
  '7': 'bg-[#039be5]',
  '8': 'bg-[#616161]',
  '9': 'bg-[#3f51b5]',
  '10': 'bg-[#0b8043]',
  '11': 'bg-[#d50000]',
};

const textColors = {
  '1': 'text-[#7986cb]', 
  '2': 'text-[#33b679]', 
  '3': 'text-[#8e24aa]', 
  '4': 'text-[#e67c73]', 
  '5': 'text-[#f6c026]', 
  '6': 'text-[#f4511e]', 
  '7': 'text-[#039be5]', 
  '8': 'text-[#616161]', 
  '9': 'text-[#3f51b5]', 
  '10': 'text-[#0b8043]', 
  '11': 'text-[#d50000]', 
};

const goalColorBg = bgColors[goal.color || '9'] || 'bg-blue-500';
const goalColorText = textColors[goal.color || '9'] || 'text-blue-500';
const progressPercent = Math.min(100, Math.round(((goal.weeklyProgress || 0) / goal.times_per_week) * 100));
---

<details name="goal-accordion" class="group bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden transition-all duration-300">
  <summary class="list-none cursor-pointer p-5 relative select-none [&::-webkit-details-marker]:hidden">
    <div class={`absolute top-0 left-0 w-1.5 h-full ${goalColorBg}`}></div>
    <div class="flex justify-between items-center pl-3">
      <div class="flex items-center gap-3">
        <span class={`${goal.icon || 'i-ph-star-fill'} ${goalColorText} text-2xl`}></span>
        <div>
          <h3 class="text-xl font-bold text-gray-800 flex items-center gap-2">{goal.name}</h3>
          <div class="flex items-center gap-4 text-sm text-gray-500 mt-1">
            <span class="flex items-center gap-1.5"><div class="i-ph-timer text-gray-400"></div>{formatDuration(goal.duration_minutes)}</span>
            <span class="flex items-center gap-1.5"><div class="i-ph-calendar-plus text-gray-400"></div>{formatTimes(goal.times_per_week)}</span>
          </div>
        </div>
      </div>
      <div class="flex items-center gap-4">
        {goal.streak > 0 && (
          <div class="bg-orange-100 text-orange-600 px-3 py-1 rounded-full text-sm font-bold flex items-center gap-1">
            <div class="i-ph-fire-fill"></div>
            {goal.streak} Week Streak
          </div>
        )}
        <div class="i-ph-caret-down text-gray-400 text-xl transition-transform duration-300 group-open:rotate-180"></div>
      </div>
    </div>
  </summary>

  <div class="px-5 pb-5 pt-2 pl-8 border-t border-gray-100">
    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-gray-50 p-4 rounded-xl border border-gray-100">
        <h4 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3 flex items-center gap-2">
          <div class="i-ph-clock-fill text-blue-500"></div> Next Up
        </h4>
        <p class="text-lg font-medium text-gray-800 mb-4">
          {goal.nextInstance ? formatDateTime(goal.nextInstance.start_time, timezone) : 'No upcoming instances found. Try syncing.'}
        </p>
        
        {goal.nextInstance && (
          <div class="flex gap-2">
            <button class="action-btn flex-1 bg-green-100 hover:bg-green-200 text-green-700 py-2 rounded-lg font-medium flex items-center justify-center gap-1 transition" data-id={goal.nextInstance.id} data-status="completed">
              ✅ Done
            </button>
            <button class="action-btn flex-1 bg-yellow-100 hover:bg-yellow-200 text-yellow-700 py-2 rounded-lg font-medium flex items-center justify-center gap-1 transition" data-id={goal.nextInstance.id} data-status="skipped">
              ⏭️ Skip
            </button>
            <button class="action-btn flex-1 bg-red-100 hover:bg-red-200 text-red-700 py-2 rounded-lg font-medium flex items-center justify-center gap-1 transition" data-id={goal.nextInstance.id} data-status="missed">
              ❌ Miss
            </button>
          </div>
        )}
      </div>

      <div class="flex flex-col justify-between">
        <div>
          <h4 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3 flex items-center gap-2">
            <div class="i-ph-trend-up text-indigo-500"></div> Weekly Progress
          </h4>
          <div class="flex justify-between text-sm font-medium mb-1">
            <span class="text-gray-700">{goal.weeklyProgress || 0} / {goal.times_per_week} completed</span>
            <span class="text-#FFBF00">{progressPercent}%</span>
          </div>
          <div class="w-full bg-gray-200 rounded-full h-2.5">
            <div class={`h-2.5 rounded-full transition-all duration-500 ${progressPercent === 100 ? 'bg-green-500' : 'bg-indigo-600'}`} style={`width: ${progressPercent}%`}></div>
          </div>
        </div>

        <div class="mt-4 flex justify-between items-end">
          <p class="text-sm text-gray-500 flex items-center gap-1">
            <span class="i-ph-trophy-fill text-yellow-500"></span>
            Lifetime: <span class="font-bold text-gray-700">{goal.lifetimeCompletions || 0}</span>
          </p>
          
          <form method="POST" action="/api/goals/delete" onsubmit="return confirm('Are you sure you want to delete this goal and remove all of its scheduled events from your calendar?');">
            <input type="hidden" name="goal_id" value={goal.id} />
            <button type="submit" class="text-xs text-red-500 hover:text-red-700 hover:underline flex items-center gap-1">
              <span class="i-ph-trash"></span> Delete Goal
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</details>

<script>
  const buttons = document.querySelectorAll('.action-btn');
  buttons.forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      const id = btn.getAttribute('data-id');
      const status = btn.getAttribute('data-status');
      
      const container = btn.closest('.flex');
      container.style.opacity = '0.5';
      container.style.pointerEvents = 'none';

      try {
        const res = await fetch('/api/instances/update', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ instance_id: id, status })
        });

        if (res.ok) {
          window.location.reload();
        } else {
          alert('Failed to update instance. Please try again.');
          container.style.opacity = '1';
          container.style.pointerEvents = 'auto';
        }
      } catch (err) {
        console.error(err);
        alert('An error occurred.');
        container.style.opacity = '1';
        container.style.pointerEvents = 'auto';
      }
    });
  });
</script>