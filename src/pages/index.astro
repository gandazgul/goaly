---
import Layout from '../layouts/Layout.astro';
import { db } from '../db';
import { getUserFromRequest } from '../lib/auth.js';
import GoalForm from '../components/GoalForm.astro';
import GoalCard from '../components/GoalCard.astro';
import Toast from '../components/Toast.astro';
import { calculateWeeklyStreak, getWeeklyProgress } from '../utils/streakCalc.js';

// Get current user if any
const user = getUserFromRequest(Astro.request);

// Fetch goals for logged-in user
let goals = [];
if (user) {
  goals = db.prepare('SELECT * FROM goals WHERE user_id = ? ORDER BY created_at DESC').all(user.id);
  
  const nowISO = new Date().toISOString();
  
  for (const goal of goals) {
    const instances = db.prepare('SELECT * FROM goal_instances WHERE goal_id = ? ORDER BY start_time').all(goal.id);
    
    goal.nextInstance = instances.find(i => i.status === 'pending' && i.start_time > nowISO) || null;
    goal.weeklyProgress = getWeeklyProgress(instances);
    goal.lifetimeCompletions = instances.filter(i => i.status === 'completed').length;
    goal.streak = calculateWeeklyStreak(instances, goal.times_per_week);
  }
}

// Check for success param
const url = new URL(Astro.request.url);
const successParam = url.searchParams.get('success');
---

<Layout>
	<div class="p-8 text-center bg-gray-50 min-h-screen font-sans">
		{successParam === 'GoalCreated' && (
			<Toast type="info" title="Awesome!" message="Your new goal has been saved." />
		)}

		{successParam === 'GoalDeleted' && (
			<Toast type="gray" message="Goal deleted successfully." />
		)}

		{successParam === 'GoalsSynced' && (
			<Toast type="indigo" title="Synced!" message="Your goals have been re-scheduled into your calendar." />
		)}

		{user ? (
			<div class="max-w-4xl mx-auto text-left">
				<div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-8 bg-white p-4 rounded-xl shadow-sm border border-gray-100">
					<div class="flex items-center gap-6">
						<div class="flex items-center">
							<img src="/logo.png" alt="Goaly Logo" class="h-16 w-auto" />
						</div>
						<div class="hidden md:block w-px h-12 bg-gray-200"></div>
						<div class="text-left">
							<p class="text-xs text-gray-500 uppercase tracking-wide">Logged in as</p>
							<p class="font-semibold text-gray-800">{user.email}</p>
						</div>
					</div>
					<div class="flex flex-wrap justify-center gap-3">
						<button onclick="document.getElementById('goal-modal').showModal()" class="text-sm bg-#005F6A text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition font-medium border border-blue-700 flex items-center gap-2">
							<div class="i-ph-plus-bold"></div>
							Add Goal
						</button>
						<form action="/api/goals/sync" method="POST">
							<button type="submit" class="text-sm bg-indigo-50 text-indigo-700 px-4 py-2 rounded-lg hover:bg-indigo-100 transition font-medium border border-indigo-200 flex items-center gap-2">
								<span class="i-ph-arrows-clockwise-fill"></span>
								Sync Calendar
							</button>
						</form>
						<a href="/profile" class="text-sm bg-gray-100 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-200 transition font-medium border border-gray-300 flex items-center gap-2">
							<div class="i-ph-gear"></div>
							Settings
						</a>
						<a href="/api/auth/logout" class="text-sm bg-red-50 text-red-600 px-4 py-2 rounded-lg hover:bg-red-100 transition font-medium border border-red-200 flex items-center gap-2">
							<div class="i-ph-sign-out"></div>
							Logout
						</a>
					</div>
				</div>

				<div class="w-full">
					<div>
						<h2 class="text-2xl font-bold mb-4 text-gray-800 flex items-center gap-2">
							<span class="i-ph-list-checks-fill text-teal-500"></span>
							Your Active Goals
						</h2>
						
						{goals.length === 0 ? (
							<div class="bg-white border-2 border-dashed border-gray-300 rounded-xl p-8 text-center text-gray-500">
								<div class="i-ph-ghost text-4xl mx-auto mb-2 text-gray-400"></div>
								<p>You don't have any active goals yet.</p>
								<p class="text-sm mt-1">Use the form to create your first one!</p>
							</div>
						) : (
							<div class="space-y-4">
								{goals.map((goal) => (
									<GoalCard goal={goal} />
								))}
							</div>
						)}
					</div>

					<dialog id="goal-modal" class="p-0 rounded-2xl shadow-xl backdrop:bg-gray-900/50 border border-gray-100 max-w-md w-full bg-white open:animate-fade-in open:animate-duration-200">
						<div class="relative">
							<button onclick="document.getElementById('goal-modal').close()" class="absolute top-6 right-6 text-gray-400 hover:text-gray-600 z-10">
								<div class="i-ph-x-bold text-xl"></div>
							</button>
							<GoalForm />
						</div>
					</dialog>
				</div>
			</div>
		) : (
			<div class="mt-16 bg-white p-8 rounded-2xl shadow-xl max-w-lg mx-auto border border-gray-100">
				<img src="/logo.png" alt="Goaly Logo" class="h-20 w-auto mx-auto mb-6" />
				<h2 class="text-2xl font-bold text-gray-800 mb-2">Build Better Habits</h2>
				<p class="text-gray-600 mb-8">
					Set your goals, choose your preferred times, and let Goaly automatically schedule them into free slots on your Google Calendar.
				</p>
				<a href="/api/auth/login" class="flex items-center justify-center gap-3 w-full bg-blue-600 text-white px-6 py-4 rounded-xl shadow-md text-lg font-semibold hover:bg-blue-700 hover:shadow-lg transition">
					<div class="i-ph-google-logo-bold text-xl"></div>
					Continue with Google
				</a>
				<p class="mt-6 text-[13px] sm:text-sm text-gray-500 whitespace-nowrap">
					By continuing, you agree to our <a href="/terms" class="text-blue-600 hover:underline">Terms of Service</a> and <a href="/privacy" class="text-blue-600 hover:underline">Privacy Policy</a>.
				</p>
			</div>
		)}
	</div>

	<script>
		const dialog = document.getElementById('goal-modal');
		if (dialog) {
			dialog.addEventListener('click', (e) => {
				const dialogDimensions = dialog.getBoundingClientRect();
				if (
					e.clientX < dialogDimensions.left ||
					e.clientX > dialogDimensions.right ||
					e.clientY < dialogDimensions.top ||
					e.clientY > dialogDimensions.bottom
				) {
					dialog.close();
				}
			});
		}
	</script>
</Layout>